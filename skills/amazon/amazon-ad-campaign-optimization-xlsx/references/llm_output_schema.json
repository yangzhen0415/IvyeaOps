{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Amazon Ad Campaign Optimization Plan",
  "description": "LLM output schema. build_xlsx.py consumes this JSON and renders the 8-sheet workbook. Field names match Chinese semantics in the xlsx; English keys for code stability.",
  "type": "object",
  "required": ["meta", "diagnosis", "actions", "negatives", "boost", "budget_redistribution", "checklist"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["asin", "marketplace", "date_range", "days", "goal", "title_subject"],
      "properties": {
        "asin": {"type": "string", "description": "目标 ASIN（无父子关系区分时填变体或父都行）"},
        "sku_or_brand": {"type": "string", "description": "可选，用于标题，如 FKPCAM FK50。若空则用 asin"},
        "title_subject": {"type": "string", "description": "Sheet 01 标题里的主体短语，如 'FKPCAM FK50' 或 'B0GWDQ5WVQ'"},
        "marketplace": {"type": "string", "enum": ["US", "UK", "DE", "CA", "JP", "FR", "ES", "IT", "MX", "AU", "AE", "BR", "SA"]},
        "date_range": {"type": "string", "description": "如 '4.21 - 5.11' 或 '2026-04-21 至 2026-05-11'"},
        "days": {"type": "integer", "minimum": 1},
        "goal": {"type": "string", "enum": ["profit", "volume", "volume_with_top_of_search_push", "clearance", "launch"]},
        "core_objective": {"type": "string", "description": "Sheet 02 标题的副标语，如 '冲 trail camera 首页顶部'"},
        "core_principle": {"type": "string", "description": "Sheet 02 章节红字原则，如 'trail camera bid 不降反升，所有动作服务于首页顶部占位'"},
        "product_notes": {"type": "string"}
      }
    },
    "diagnosis": {
      "type": "object",
      "description": "Sheet 01 现状诊断的数据。campaign_efficiency 必须含合计行（在 build 阶段自动算）",
      "required": ["campaign_efficiency", "keyword_blackholes"],
      "properties": {
        "campaign_efficiency": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["campaign", "spend", "orders", "cpo", "acos", "budget_share", "order_share", "verdict"],
            "properties": {
              "campaign": {"type": "string"},
              "spend": {"type": "number", "description": "单位美元"},
              "orders": {"type": "integer", "minimum": 0},
              "cpo": {"type": "number", "description": "每单成本，spend/orders；orders=0 则填 0 + verdict 中说明"},
              "acos": {"type": ["number", "string"], "description": "ACOS 百分比，可填 138 或 '138%'，build 阶段统一格式化"},
              "budget_share": {"type": ["number", "string"], "description": "预算占比百分比"},
              "order_share": {"type": ["number", "string"], "description": "单量占比百分比"},
              "verdict": {"type": "string", "enum": ["✓✓ 高效", "✓ 健康", "❌ 效率黑洞", "⚠️ 一般"]}
            }
          }
        },
        "keyword_blackholes": {
          "type": "array",
          "description": "燃费 Top 黑洞词 + 高潜力转化词，建议 5-10 行 + 一行'其他N词(0单)'汇总。最后一行可选'合计'。",
          "items": {
            "type": "object",
            "required": ["keyword", "spend", "orders", "ctr", "acos", "comment", "tag"],
            "properties": {
              "keyword": {"type": "string"},
              "spend": {"type": "number"},
              "orders": {"type": "integer"},
              "ctr": {"type": ["number", "string"], "description": "CTR 百分比"},
              "acos": {"type": ["number", "string"]},
              "comment": {"type": "string", "description": "短评，如'核心大词，单词吃 37% 预算'"},
              "tag": {"type": "string", "enum": ["黑洞", "高潜", "稳定", "一般", "已转化", "其他汇总", "合计"], "description": "决定该行底色"}
            }
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "description": "Sheet 02 核心动作。按优先级 P0→P3 排序。每条 expected 必须含数据预期或 SIF 证据引用。",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["priority", "title", "where", "params", "expected", "timing"],
        "properties": {
          "priority": {"type": "string", "enum": ["🔴 P0", "🟠 P1", "🟡 P2", "🟢 P3"]},
          "title": {"type": "string", "description": "动作短标题，可换行（用 \\n）"},
          "where": {"type": "string", "description": "操作位置，如'后台→核心词Campaign→竞价'"},
          "params": {"type": "string", "description": "具体参数，可换行展示多条参数"},
          "expected": {"type": "string", "description": "预期效果，必须含数据或 SIF 证据"},
          "timing": {"type": "string", "description": "执行时机，如'今天'/'本周'/'Day 3'"}
        }
      }
    },
    "new_campaigns": {
      "type": "array",
      "description": "Sheet 03 新建 Campaign。每个 campaign 一组参数表。可空（无新建时）。",
      "items": {
        "type": "object",
        "required": ["name", "section_title", "params"],
        "properties": {
          "name": {"type": "string", "description": "如 'SP-Exact-TrailCamera-ToS-Only'"},
          "section_title": {"type": "string", "description": "Sheet 03 红字章节标题，如 'Campaign 1：SP-Exact-TrailCamera-ToS（首页顶部专属）'"},
          "params": {
            "type": "array",
            "minItems": 5,
            "items": {
              "type": "object",
              "required": ["key", "value", "note", "required"],
              "properties": {
                "key": {"type": "string", "description": "参数项名，如 'Campaign名称'"},
                "value": {"type": "string", "description": "设置值"},
                "note": {"type": "string", "description": "说明"},
                "required": {"type": "string", "enum": ["必填", "选填", "⚠️ 同步操作"]}
              }
            }
          }
        }
      }
    },
    "negatives": {
      "type": "object",
      "required": ["protected_keywords", "groups"],
      "properties": {
        "protected_keywords": {
          "type": "array",
          "description": "保护词分组列表，每条对应 Sheet 04 顶部红框里的一行 🛡️ chip",
          "items": {"type": "string", "description": "如 'trail camera / trail cameras / trail cam / trail cams / trailcam'"}
        },
        "groups": {
          "type": "array",
          "description": "按 campaign 分组的否词清单，每个 group 渲染为一节",
          "items": {
            "type": "object",
            "required": ["section_title", "items"],
            "properties": {
              "section_title": {"type": "string", "description": "如 '一、自动广告 - 否定精准'"},
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["term", "type", "reason", "wasted_usd"],
                  "properties": {
                    "term": {"type": "string"},
                    "type": {"type": "string", "enum": ["❌ 立即否", "⚠️ 观察"]},
                    "reason": {"type": "string"},
                    "wasted_usd": {"type": ["number", "string"], "description": "21 天浪费金额，可填 0"}
                  }
                }
              }
            }
          }
        },
        "summary_line": {"type": "string", "description": "Sheet 04 末尾汇总行，如 '📊 直接省: ~$22.24（过去21天浪费） | 长期: 月省$50+'"}
      }
    },
    "boost": {
      "type": "object",
      "description": "Sheet 05 加码清单。groups 按 campaign 分组",
      "required": ["groups"],
      "properties": {
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["section_title", "items"],
            "properties": {
              "section_title": {"type": "string", "description": "如 '一、核心词Campaign内 - bid加码'"},
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["keyword", "current_bid", "new_bid", "change", "reason", "expected"],
                  "properties": {
                    "keyword": {"type": "string"},
                    "current_bid": {"type": "string", "description": "如 '$3.16' 或 '—'（自动广告挖词）"},
                    "new_bid": {"type": "string"},
                    "change": {"type": "string", "description": "如 '+18%' / '双轨加码' / '新增'"},
                    "reason": {"type": "string"},
                    "expected": {"type": "string"},
                    "tag": {"type": "string", "enum": ["核心", "高潜", "迁移", "拓词"], "description": "决定该行底色（核心绿/高潜黄/迁移浅蓝/拓词金）"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "budget_redistribution": {
      "type": "object",
      "required": ["before_after", "notes"],
      "properties": {
        "before_after": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["campaign", "before_spend", "before_share", "after_spend", "after_share", "trend"],
            "properties": {
              "campaign": {"type": "string"},
              "before_spend": {"type": ["number", "string"]},
              "before_share": {"type": ["number", "string"]},
              "after_spend": {"type": ["number", "string"]},
              "after_share": {"type": ["number", "string"]},
              "trend": {"type": "string", "enum": ["⬆️ 增加", "⬇️ 缩减", "➡️ 保持", "🆕 新增"]}
            }
          }
        },
        "notes": {
          "type": "array",
          "description": "Sheet 06 末尾的 1-3 条说明文本",
          "items": {"type": "string"}
        }
      }
    },
    "checklist": {
      "type": "object",
      "required": ["week1", "week2"],
      "properties": {
        "week1": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["day", "task", "where", "minutes"],
            "properties": {
              "day": {"type": "string", "description": "如 'Day 1 周一'"},
              "task": {"type": "string"},
              "where": {"type": "string"},
              "minutes": {"type": ["integer", "string"], "description": "如 10 或 '10分钟'"}
            }
          }
        },
        "week2": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["day", "task", "where", "minutes"],
            "properties": {
              "day": {"type": "string"},
              "task": {"type": "string"},
              "where": {"type": "string"},
              "minutes": {"type": ["integer", "string"]}
            }
          }
        },
        "review_metrics": {
          "type": "array",
          "description": "复盘指标对比表（可选，Sheet 07 末尾），每条含 metric/baseline/target",
          "items": {
            "type": "object",
            "properties": {
              "metric": {"type": "string"},
              "baseline": {"type": "string"},
              "target": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
