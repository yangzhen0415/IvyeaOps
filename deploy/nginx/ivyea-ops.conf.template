# Rendered by scripts/render-deploy.sh from deploy/install.conf.
# Install:
#   sudo cp deploy/dist/nginx/ivyea-ops.conf /etc/nginx/conf.d/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Certbot:
#   sudo certbot certonly --nginx -d ${SERVER_NAME}

# Rate-limit zone for the login endpoint. 10 r/m per client IP is well above
# any legitimate human retry rate but low enough to blunt credential-stuffing.
# 10m of shared memory tracks ~160k unique IPs, more than enough.
limit_req_zone $binary_remote_addr zone=ivyeaops_login:10m rate=10r/m;

# --- HTTP → HTTPS redirect ---
server {
    listen 80;
    listen [::]:80;
    server_name ${SERVER_NAME};
    return 301 https://$host$request_uri;
}

# --- HTTPS main server ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name ${SERVER_NAME};

    ssl_certificate     /etc/letsencrypt/live/${SERVER_NAME}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${SERVER_NAME}/privkey.pem;

    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    client_max_body_size 50m;

    # --- Security headers ---
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Content-Security-Policy "frame-ancestors 'self'" always;

    # Internal auth check for protected subresources on this same origin.
    location = /_auth {
        internal;
        proxy_pass http://127.0.0.1:${IVYEA_OPS_PORT}/api/auth/verify;
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
        proxy_set_header Host $host;
        proxy_set_header Cookie $http_cookie;
    }

    # --- Login rate limit ---
    # Brute force against the single admin account gets throttled here.
    # burst=5 nodelay allows a small flurry (form resubmit, double-click)
    # before returning 429.
    location = /api/auth/login {
        limit_req zone=ivyeaops_login burst=5 nodelay;
        limit_req_status 429;
        proxy_pass http://127.0.0.1:${IVYEA_OPS_PORT};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }

    # --- .apk download (Android client) ---
    # Force download with correct MIME so mobile browsers install the apk
    # instead of displaying gibberish.
    location ~* \.apk$ {
        proxy_pass http://127.0.0.1:${IVYEA_OPS_PORT};
        default_type application/vnd.android.package-archive;
        add_header Content-Disposition 'attachment; filename="ivyea-ops.apk"';
    }

    # --- IvyeaOps: everything by default ---
    # FastAPI serves both /api/* and the built React SPA on 127.0.0.1:${IVYEA_OPS_PORT}.
    location / {
        proxy_pass http://127.0.0.1:${IVYEA_OPS_PORT};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        # Long timeouts for the slow AI-synthesis / scrape endpoints that
        # legitimately take minutes; tune down if your traffic is short.
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
        proxy_connect_timeout 60s;
        send_timeout 300s;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    location @login_redirect {
        return 302 /login;
    }

    # === OPTIONAL: skill-studio static dist at /skill-studio/ ===
    # Delete this block if you don't deploy skill-studio.
    location /skill-studio/ {
        auth_request /_auth;
        error_page 401 = @login_redirect;
        alias ${SKILL_STUDIO_DIST}/;
        try_files $uri $uri/ ${SKILL_STUDIO_DIST}/index.html =404;
        add_header Cache-Control "public, max-age=3600";
    }

    # === OPTIONAL: claudecodeui at /cli/ ===
    # Delete this block if you don't run claudecodeui.
    location /cli/ {
        proxy_pass http://127.0.0.1:${CLAUDECODEUI_PORT}/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # === OPTIONAL: amazon-image-workflow at /imgflow ===
    # Delete these three blocks if you don't run the imgflow service.
    location = /imgflow {
        proxy_pass http://127.0.0.1:${IVYEA_OPS_PORT};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
    location = /imgflow/ {
        return 302 /imgflow;
    }
    location /imgflow/ {
        proxy_pass http://127.0.0.1:${IMGFLOW_WEB_PORT};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Cache-Control "no-store" always;
    }
    location /imgflow-api/ {
        proxy_pass http://127.0.0.1:${IMGFLOW_API_PORT}/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}
